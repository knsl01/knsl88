# Supabase (auth + cloud data) — https://supabase.com/dashboard
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI providers — server-side keys for /api/ai (NOT VITE_ prefixed).
# Local dev: copy needed lines into .env.local (auto-loaded by Vite into the dev proxy).
# Vercel: set in Environment Variables, then redeploy.
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_MODEL=
GROQ_MODEL=
CLAUDE_MODEL=
OLLAMA_HOST=
OLLAMA_MODEL=
AI_FETCH_TIMEOUT_MS=

# Optional: override defaults
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional legacy backend (Vercel + PostgreSQL)
DATABASE_URL=
JWT_SECRET=
